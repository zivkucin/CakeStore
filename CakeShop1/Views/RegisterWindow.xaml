<Window x:Class="CakeShop1.Views.RegisterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Register"
        Height="460" Width="350"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen">

    <Border Background="White" CornerRadius="10" Padding="20" Margin="20">
        <StackPanel>

            <TextBlock Text="Create Account"
                       FontSize="20"
                       FontWeight="Bold"
                       Margin="0,0,0,20"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="First Name"/>
            <TextBox x:Name="txtFirstName" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Last Name"/>
            <TextBox x:Name="txtLastName" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Email"/>
            <TextBox x:Name="txtEmail" Height="30" Margin="0,5,0,10"/>

            <TextBlock Text="Password"/>
            <PasswordBox x:Name="txtPassword" Height="30" Margin="0,5,0,20"/>

            <Button Content="Register"
                    Height="35"
                    Background="#4CAF50"
                    Foreground="White"
                    Click="Register_Click"/>

        </StackPanel>
    </Border>
</Window>
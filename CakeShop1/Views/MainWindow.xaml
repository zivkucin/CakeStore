<Window x:Class="CakeShop1.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Orders"
        Height="500" Width="750"
        Background="#F5F5F5"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ===================== -->
        <!-- HEADER -->
        <!-- ===================== -->
        <TextBlock Text="🧁 Orders Dashboard"
                   FontSize="22"
                   FontWeight="Bold"
                   Margin="0,0,0,15"
                   Foreground="#333"/>

        <!-- ===================== -->
        <!-- MAIN CARD -->
        <!-- ===================== -->
        <Border Grid.Row="1"
                Background="White"
                CornerRadius="10"
                Padding="10"
                BorderBrush="#DDD"
                BorderThickness="1">

            <Grid>

                <!-- DataGrid -->
                <DataGrid x:Name="dataGrid"
                          AutoGenerateColumns="True"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          Background="White"
                          BorderThickness="0"
                          RowBackground="#FAFAFA"
                          AlternatingRowBackground="#F0F0F0"
                          GridLinesVisibility="None"
                          HeadersVisibility="Column"/>

                <!-- No data -->
                <TextBlock x:Name="txtNoData"
                           Text="No orders yet 🧁"
                           FontSize="18"
                           Foreground="Gray"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           Visibility="Collapsed"/>

            </Grid>
        </Border>

        <!-- ===================== -->
        <!-- BUTTONS -->
        <!-- ===================== -->
        <StackPanel Grid.Row="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right"
                    Margin="0,15,0,0">

            <!-- LOGOUT -->
            <Button Content="Logout"
                    Width="100"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#E53935"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="Logout_Click"/>

            <!-- NEW ORDER -->
            <Button Content="New Order"
                    Width="120"
                    Height="35"
                    Margin="0,0,10,0"
                    Background="#43A047"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="NewOrder_Click"/>

            <!-- CHANGE STATUS -->
            <Button x:Name="btnChangeStatus"
                    Content="Change Status"
                    Width="140"
                    Height="35"
                    Background="#1E88E5"
                    Foreground="White"
                    BorderThickness="0"
                    FontWeight="SemiBold"
                    Click="ChangeStatus_Click"/>

        </StackPanel>

    </Grid>
</Window>
<Window x:Class="CakeShop1.Views.OrderWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Create Order"
        Height="660" Width="420"
        Background="#F3F4F6"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Border Background="White"
                CornerRadius="15"
                Padding="20"
                Margin="20">

            <StackPanel>

                <TextBlock Text="🧁 Create Order"
                           FontSize="22"
                           FontWeight="Bold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,15"/>

                <TextBlock Text="Product"/>
                <ComboBox x:Name="cbProduct"
                          Height="35"
                          SelectionChanged="cbProduct_SelectionChanged"/>

                <TextBlock Text="Quantity" Margin="0,10,0,0"/>
                <TextBox x:Name="txtQuantity" Height="35"/>

                <TextBlock Text="Delivery Address" Margin="0,10,0,0"/>
                <TextBox x:Name="txtAddress" Height="35"/>

                <Button Content="Add to Cart"
                        Click="AddToCart_Click"
                        Background="#6366F1"
                        Foreground="White"
                        Margin="0,10,0,0"
                        Height="35"/>

                <!-- CART -->
                <DataGrid x:Name="dgCart"
                          Height="150"
                          Margin="0,10,0,0"
                          AutoGenerateColumns="False">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Product" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Qty" Binding="{Binding Quantity}" />
                        <DataGridTextColumn Header="Price" Binding="{Binding Price}" />
                        <DataGridTextColumn Header="Total" Binding="{Binding Total}" />
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Text="Total" Margin="0,10,0,0"/>
                <TextBlock x:Name="txtTotal"
                           FontSize="16"
                           FontWeight="Bold"
                           Foreground="#10B981"
                           Text="0 RSD"/>

                <Button Content="Create Order"
                        Click="SaveOrder_Click"
                        Background="#10B981"
                        Foreground="White"
                        Margin="0,15,0,0"
                        Height="40"/>

            </StackPanel>
        </Border>
    </Grid>
</Window>